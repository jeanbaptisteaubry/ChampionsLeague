<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title|default('App') }}</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 1rem auto; max-width: 900px; }
      nav a { margin-right: .75rem; }
      .flash-ok { color: #0a0; }
      .flash-err { color: #a00; }
      form label { display:block; margin-top:.5rem }
      input, button { padding:.4rem .6rem; }
    </style>
  </head>
  <body>
    {% if app.impersonator is defined and app.impersonator %}
      <div style="border:2px solid #b36b00; background:#fff3cd; padding:.75rem; margin-bottom:1rem">
        <strong>Mode assistance :</strong>
        vous agissez comme {{ app.user.pseudo }}. Les paris saisis seront r&eacute;ellement enregistr&eacute;s pour ce participant.
        <form method="post" action="/assistance/stop" style="display:inline; margin-left:.75rem">
          <input type="hidden" name="_csrf" value="{{ app.csrf }}">
          <button type="submit">Revenir au compte administrateur</button>
        </form>
      </div>
    {% endif %}
    <nav>
      <a href="/">Accueil</a>
      {% if app.user is defined and app.user %}
        {% if app.user.typeLibelle == 'administrateur' %}
          <a href="/admin/users">Utilisateurs</a>
          <a href="/admin/campagnes">Campagnes</a>
          <a href="/admin/types">Types de phase</a>
          <a href="/admin/home-text">Texte d'accueil</a>
        {% else %}
          <a href="/parieur/campagnes">Campagnes</a>
          {% if not (app.impersonator is defined and app.impersonator) %}
            <a href="/parieur/password">Changer le mot de passe</a>
            <a href="/parieur/pseudo">Changer le pseudo</a>
          {% endif %}
        {% endif %}
        {% if not (app.impersonator is defined and app.impersonator) %}
          <a href="/logout">D&eacute;connexion ({{ app.user.pseudo }})</a>
        {% endif %}
      {% else %}
        <a href="/login">Connexion</a>
      {% endif %}
    </nav>
    <hr/>
    {% block body %}{% endblock %}
  </body>
</html>
