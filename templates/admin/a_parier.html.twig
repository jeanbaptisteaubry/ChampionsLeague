{% extends 'base.html.twig' %}
{% block body %}
  <h1>Éléments à parier — {{ campagne.libelle }} — {{ phase.libelle }} (Phase #{{ phase.idPhaseCampagne }})</h1>
  <p>
    <a href="/admin/campagnes/{{ campagne.idCampagnePari }}/phases">← Retour aux phases de la campagne</a>
  </p>
  <p>
    <a href="/admin/phases/{{ phase.idPhaseCampagne }}/api-football">V&eacute;rifier les r&eacute;sultats avec API-Football</a>
    &mdash; <a href="/admin/phases/{{ phase.idPhaseCampagne }}/thesportsdb">V&eacute;rifier avec TheSportsDB</a>
  </p>
  {% if type %}<p>Type de phase: {{ type.libelle }}</p>{% endif %}
  {% if ok %}<p class="flash-ok">{{ ok }}</p>{% endif %}
  {% if error %}<p class="flash-err">{{ error }}</p>{% endif %}
  <form method="post" action="/admin/phases/{{ phase.idPhaseCampagne }}/a-parier">
    <input type="hidden" name="_csrf" value="{{ app.csrf }}">
    <label>Libellé à parier <input name="libellePari" required></label>
    <button>Ajouter</button>
  </form>
  <h3>Ajout en lot</h3>
  <form method="post" action="/admin/phases/{{ phase.idPhaseCampagne }}/a-parier">
    <input type="hidden" name="_csrf" value="{{ app.csrf }}">
    <label>Un libellé par ligne</label><br>
    <textarea name="batch" rows="6" cols="60" placeholder="Exemple:\nEquipe A - Equipe B\nEquipe C - Equipe D\n..."></textarea>
    <br>
    <button>Ajouter en lot</button>
  </form>
  <h2>Liste</h2>
  {% if items|length == 0 %}
    <p>Pas d'élément</p>
  {% else %}
    <form method="post" action="/admin/phases/{{ phase.idPhaseCampagne }}/a-parier/resultats" style="margin:.5rem 0 1rem 0;">
      <input type="hidden" name="_csrf" value="{{ app.csrf }}">
      <table border="1" cellpadding="6" cellspacing="0" style="border-collapse:collapse">
        <thead>
          <tr>
            <th>À parier</th>
            {% for i in 1..nb %}
              <th>{{ labels[i] ?? ('Valeur ' ~ i) }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for it in items %}
            <tr>
              <td>#{{ it.idAParier }} — {{ it.libellePari }}</td>
              {% for i in 1..nb %}
                {% set label = (labels[i] ?? ('Valeur ' ~ i)) %}
                {% set val = (results[it.idAParier][i] ?? '') %}
                <td>
                  {% if 'qualifi' in (label|lower) %}
                    <select name="res[{{ it.idAParier }}][{{ i }}]" data-qualifier-for="{{ it.idAParier }}">
                      <option value="">-</option>
                      <option value="1" {% if val == '1' %}selected{% endif %}>Domicile</option>
                      <option value="2" {% if val == '2' %}selected{% endif %}>Ext&eacute;rieur</option>
                    </select>
                  {% else %}
                    <input name="res[{{ it.idAParier }}][{{ i }}]" value="{{ val }}" placeholder="{{ label }}" data-score-item="{{ it.idAParier }}" data-score-number="{{ i }}">
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
      <div style="margin-top:.5rem">
        <button>Enregistrer tous les résultats</button>
      </div>
    </form>
  {% endif %}
  <script>
    (function () {
      function setAutoValue(row, qualifier, value) {
        var itemId = qualifier.getAttribute('data-qualifier-for');
        var hidden = row.querySelector('input[type="hidden"][data-qualifier-hidden-for="' + itemId + '"]');
        qualifier.value = value;
        qualifier.disabled = true;
        qualifier.style.backgroundColor = '#eee';
        if (!hidden) {
          hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = qualifier.name;
          hidden.setAttribute('data-qualifier-hidden-for', itemId);
          qualifier.parentNode.appendChild(hidden);
        }
        hidden.value = value;
      }

      function clearAutoValue(row, qualifier, clearValue) {
        var itemId = qualifier.getAttribute('data-qualifier-for');
        var hidden = row.querySelector('input[type="hidden"][data-qualifier-hidden-for="' + itemId + '"]');
        if (hidden) { hidden.remove(); }
        if (qualifier.getAttribute('data-original-disabled') !== '1') {
          qualifier.disabled = false;
        }
        qualifier.style.backgroundColor = '';
        if (clearValue) { qualifier.value = ''; }
      }

      function syncQualifier(row) {
        var home = row.querySelector('[data-score-number="1"]');
        var away = row.querySelector('[data-score-number="2"]');
        var qualifier = row.querySelector('[data-qualifier-for]');
        if (!home || !away || !qualifier) { return; }

        var homeValue = home.value.trim();
        var awayValue = away.value.trim();
        var homeScore = parseInt(homeValue, 10);
        var awayScore = parseInt(awayValue, 10);
        var hasScores = homeValue !== '' && awayValue !== '' && !isNaN(homeScore) && !isNaN(awayScore);

        if (!hasScores || homeScore === awayScore) {
          clearAutoValue(row, qualifier, !hasScores);
          return;
        }

        setAutoValue(row, qualifier, homeScore > awayScore ? '1' : '2');
      }

      document.querySelectorAll('[data-qualifier-for]').forEach(function (qualifier) {
        qualifier.setAttribute('data-original-disabled', qualifier.disabled ? '1' : '0');
        var row = qualifier.closest('tr');
        if (!row) { return; }
        row.querySelectorAll('[data-score-number="1"], [data-score-number="2"]').forEach(function (input) {
          input.addEventListener('input', function () { syncQualifier(row); });
        });
        syncQualifier(row);
      });
    })();
  </script>
{% endblock %}
