{% extends 'base.html.twig' %}
{% block body %}
  <h1>Phases &mdash; Campagne: {{ campagne.libelle }}</h1>
  {% if ok %}<p class="flash-ok">{{ ok }}</p>{% endif %}
  {% if error %}<p class="flash-err">{{ error }}</p>{% endif %}
  <form method="post" action="/admin/campagnes/{{ campagne.idCampagnePari }}/phases">
    <input type="hidden" name="_csrf" value="{{ app.csrf }}">
    <label>Ordre <input type="number" name="ordre" value="1" min="1" required></label>
    <label>Libell&eacute; <input name="libelle" required></label>
    <label>Date limite
      <input type="datetime-local" name="dateheureLimite" step="1" required>
    </label>
    <label>Type
      <select name="idTypePhase" required>
        {% for t in types %}<option value="{{ t.idTypePhase }}">{{ t.libelle }}</option>{% endfor %}
      </select>
    </label>
    <button>Cr&eacute;er</button>
  </form>
  <h2>Liste</h2>
  <ul>
    {% for p in phases %}
      {% set count = (apCounts[p.idPhaseCampagne] ?? 0) %}
      {% set betCount = (phaseBetCounts[p.idPhaseCampagne] ?? 0) %}
      {% set betStatus = (betStatuses[p.idPhaseCampagne] ?? {}) %}
      {% set pointStatus = (pointStatuses[p.idPhaseCampagne] ?? {}) %}
      <li>#{{ p.idPhaseCampagne }} &mdash; {{ p.ordre }} &mdash; {{ p.libelle }} &mdash; {{ p.typeLibelle }} &mdash; Limite: {{ p.dateheureLimite }} &mdash;
        <a href="/admin/phases/{{ p.idPhaseCampagne }}/a-parier">G&eacute;rer AParier</a> &mdash;
        <a href="/admin/phases/{{ p.idPhaseCampagne }}/calculs">Calculs de points</a> &mdash;
        <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/reminder" style="display:inline" onsubmit="return confirm('Envoyer un email de rappel a tous les inscrits non verrouilles ?');">
          <input type="hidden" name="_csrf" value="{{ app.csrf }}">
          <button>Envoyer rappel</button>
        </form>
        <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/recap" style="display:inline" onsubmit="return confirm('Envoyer le recapitulatif (tableau) a tous les inscrits ?');">
          <input type="hidden" name="_csrf" value="{{ app.csrf }}">
          <button>Envoyer r&eacute;capitulatif</button>
        </form>
        {% if betCount == 0 %}
          <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/delete" style="display:inline" onsubmit="return confirm('Supprimer cette phase ?');">
            <input type="hidden" name="_csrf" value="{{ app.csrf }}">
            <button>Supprimer</button>
          </form>
        {% else %}
          <em style="color:#888">({{ betCount }} pari(s) enregistr&eacute;(s) &mdash; suppression verrouill&eacute;e)</em>
        {% endif %}

        <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/extend" style="display:inline-flex; align-items:center; gap:.25rem; margin-left:.5rem" onsubmit="return confirm('Prolonger la date limite de cette phase ?');">
          <input type="hidden" name="_csrf" value="{{ app.csrf }}">
          <label style="display:inline; margin:0">
            Prolonger de
            <input type="number" name="hours" value="2" min="1" max="168" required style="width:4.5rem">
            heure(s)
          </label>
          <button type="submit">Ajouter</button>
        </form>

        <div style="margin:.4rem 0 .8rem 1rem">
          <strong>&Eacute;tat des paris :</strong>
          {% if (betStatus.participants ?? [])|length == 0 %}
            aucun participant inscrit
          {% elseif (betStatus.expectedValues ?? 0) == 0 %}
            phase &agrave; configurer
          {% else %}
            {{ betStatus.counts.locked|default(0) }} verrouill&eacute;(s),
            {{ betStatus.counts.complete|default(0) }} complet(s),
            {{ betStatus.counts.in_progress|default(0) }} en cours,
            {{ betStatus.counts.not_started|default(0) }} non commenc&eacute;(s)
          {% endif %}

          {% if (betStatus.participants ?? [])|length > 0 %}
            <details style="margin-top:.25rem">
              <summary>Voir le d&eacute;tail par participant</summary>
              <table border="1" cellpadding="5" cellspacing="0" style="border-collapse:collapse; margin-top:.4rem">
                <thead>
                  <tr>
                    <th>Participant</th>
                    <th>&Eacute;tat</th>
                    <th>Valeurs renseign&eacute;es</th>
                    <th>Assistance</th>
                  </tr>
                </thead>
                <tbody>
                  {% for participant in betStatus.participants %}
                    <tr>
                      <td>{{ participant.pseudo }}</td>
                      <td>
                        {% if participant.status == 'locked' %}
                          Verrouill&eacute;
                        {% elseif participant.status == 'complete' %}
                          Complet
                        {% elseif participant.status == 'in_progress' %}
                          En cours
                        {% else %}
                          Non commenc&eacute;
                        {% endif %}
                      </td>
                      <td style="text-align:center">
                        {{ participant.filledValues }}/{{ participant.expectedValues }}
                      </td>
                      <td>
                        <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/assistance/{{ participant.idUtilisateur }}" style="display:inline" onsubmit="return confirm('Passer temporairement sur le compte de ce participant ? Les paris saisis seront reellement enregistres pour lui.');">
                          <input type="hidden" name="_csrf" value="{{ app.csrf }}">
                          <button type="submit">Tester ses paris</button>
                        </form>
                        {% if participant.status == 'locked' %}
                          <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/unlock/{{ participant.idUtilisateur }}" style="display:inline" onsubmit="return confirm('Deverrouiller les paris de ce participant ?');">
                            <input type="hidden" name="_csrf" value="{{ app.csrf }}">
                            <button type="submit">D&eacute;verrouiller</button>
                          </form>
                        {% else %}
                          <form method="post" action="/admin/phases/{{ p.idPhaseCampagne }}/lock/{{ participant.idUtilisateur }}" style="display:inline" onsubmit="return confirm('Verrouiller et valider les paris de ce participant ?');">
                            <input type="hidden" name="_csrf" value="{{ app.csrf }}">
                            <button type="submit">Verrouiller / valider</button>
                          </form>
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </details>
          {% endif %}
        </div>

        <div style="margin:.4rem 0 .8rem 1rem">
          <strong>&Eacute;tat des points :</strong>
          {% if (pointStatus.participants ?? [])|length == 0 %}
            aucun participant verrouill&eacute;
          {% elseif (pointStatus.calculationCount ?? 0) == 0 %}
            calcul des points non configur&eacute;
          {% elseif (pointStatus.itemCount ?? 0) == 0 %}
            aucun pari configur&eacute;
          {% else %}
            {{ pointStatus.officialCount|default(0) }}/{{ pointStatus.itemCount|default(0) }}
            r&eacute;sultat(s) officiel(s) saisi(s)
          {% endif %}

          {% if (pointStatus.ranking ?? [])|length > 0 %}
            <ol style="margin:.35rem 0">
              {% for participant in pointStatus.ranking %}
                <li>
                  {{ participant.pseudo }} :
                  <strong>{{ participant.total }} point{% if participant.total != 1 %}s{% endif %}</strong>
                </li>
              {% endfor %}
            </ol>

            {% if (pointStatus.items ?? [])|length > 0 %}
              <details>
                <summary>Voir le d&eacute;tail des points par pari</summary>
                <table border="1" cellpadding="5" cellspacing="0" style="border-collapse:collapse; margin-top:.4rem">
                  <thead>
                    <tr>
                      <th>&Agrave; parier</th>
                      <th>R&eacute;sultat officiel</th>
                      {% for participant in pointStatus.participants %}
                        <th>{{ participant.pseudo }}</th>
                      {% endfor %}
                    </tr>
                  </thead>
                  <tbody>
                    {% for item in pointStatus.items %}
                      {% set official = pointStatus.official[item.idAParier] ?? {} %}
                      {% set officialDisplay = pointStatus.officialHtml[item.idAParier] ?? '' %}
                      <tr>
                        <td>{{ item.libellePari }}</td>
                        <td style="text-align:center">
                          {{ officialDisplay|raw }}
                        </td>
                        {% for participant in pointStatus.participants %}
                          {% set bet = pointStatus.cells[item.idAParier][participant.idUtilisateur] ?? '' %}
                          {% set betDisplay = pointStatus.htmlCells[item.idAParier][participant.idUtilisateur] ?? bet %}
                          {% set earned = pointStatus.points[item.idAParier][participant.idUtilisateur] ?? 0 %}
                          <td style="text-align:center">
                            {% if bet %}
                              {{ betDisplay|raw }}<br>
                              <strong>{{ earned }} pt{% if earned != 1 %}s{% endif %}</strong>
                            {% else %}
                              -
                            {% endif %}
                          </td>
                        {% endfor %}
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </details>
            {% endif %}
          {% endif %}
        </div>
      </li>
    {% else %}
      <li>Pas de phase</li>
    {% endfor %}
  </ul>
{% endblock %}
